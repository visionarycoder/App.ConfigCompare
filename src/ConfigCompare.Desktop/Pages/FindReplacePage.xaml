<Page
    x:Class="ConfigCompare.Desktop.Pages.FindReplacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16">
        <StackPanel MaxWidth="600" Spacing="12">
            <TextBlock Text="Find &amp; Replace" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

            <TextBlock Text="Endpoint" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="EndpointBox" PlaceholderText="https://your-store.azconfig.io"/>

            <TextBlock Text="Find Value" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="FindBox" PlaceholderText="Value to find"/>

            <TextBlock Text="Replace With" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="ReplaceBox" PlaceholderText="Replacement value"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Find &amp; Replace" Click="Execute_Click"
                        Style="{ThemeResource AccentButtonStyle}"/>
                <Button Content="Clear" Click="Clear_Click"/>
                <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20"/>
            </StackPanel>

            <TextBlock x:Name="StatusText" Text="" TextWrapping="Wrap"/>

            <StackPanel x:Name="ResultsPanel" Visibility="Collapsed" Spacing="4">
                <TextBlock x:Name="CountText" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <TextBlock Text="Affected Keys:" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <ScrollViewer MaxHeight="200">
                    <TextBlock x:Name="AffectedKeysText" TextWrapping="Wrap" FontFamily="Consolas"/>
                </ScrollViewer>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
