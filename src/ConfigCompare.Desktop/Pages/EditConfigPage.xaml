<Page
    x:Class="ConfigCompare.Desktop.Pages.EditConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16">
        <StackPanel MaxWidth="600" Spacing="12">
            <TextBlock Text="Edit Configuration" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

            <TextBlock Text="Endpoint" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="EndpointBox" PlaceholderText="https://your-store.azconfig.io"/>

            <TextBlock Text="Key" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="KeyBox" PlaceholderText="e.g. MyApp:Settings:ApiUrl"/>

            <TextBlock Text="Value" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="ValueBox" PlaceholderText="Configuration value"
                     AcceptsReturn="True" Height="80" TextWrapping="Wrap"/>

            <TextBlock Text="Label (optional)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="LabelBox" PlaceholderText="e.g. Production"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="SaveBtn" Content="Save" Click="Save_Click"
                        Style="{ThemeResource AccentButtonStyle}"/>
                <Button Content="Clear" Click="Clear_Click"/>
                <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20"/>
            </StackPanel>

            <TextBlock x:Name="StatusText" Text="" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Page>
