<Page
    x:Class="ConfigCompare.Desktop.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16">
        <StackPanel MaxWidth="500" Spacing="20">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

            <!-- Theme -->
            <StackPanel Spacing="8">
                <TextBlock Text="Appearance" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                <TextBlock Text="Theme" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <RadioButtons x:Name="ThemeSelector" SelectionChanged="ThemeSelector_SelectionChanged">
                    <RadioButton Content="System default" Tag="System" IsChecked="True"/>
                    <RadioButton Content="Light" Tag="Light"/>
                    <RadioButton Content="Dark" Tag="Dark"/>
                </RadioButtons>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- About -->
            <StackPanel Spacing="8">
                <TextBlock Text="About" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                <StackPanel Spacing="4">
                    <TextBlock Text="ConfigCompare" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind AppVersion, Mode=OneTime}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="Azure App Configuration comparison and management tool."
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
