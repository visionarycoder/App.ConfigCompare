<Page
    x:Class="ConfigCompare.Desktop.Pages.ComparePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ConfigCompare.Desktop.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Compare Configurations"
                   Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" x:Name="LeftComboBox"
                      PlaceholderText="Select left configuration"
                      HorizontalAlignment="Stretch" Margin="0,0,8,0"/>
            <TextBlock Grid.Column="1" Text="vs" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="2" x:Name="RightComboBox"
                      PlaceholderText="Select right configuration"
                      HorizontalAlignment="Stretch" Margin="0,0,8,0"/>
            <Button Grid.Column="3" Content="Compare"
                    Click="Compare_Click"
                    Style="{ThemeResource AccentButtonStyle}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Only in Left -->
            <Grid Grid.Column="0" Margin="0,0,6,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" CornerRadius="4,4,0,0" Padding="8,6" Background="#FFE6E6">
                    <TextBlock Text="Only in Left" FontWeight="SemiBold" Foreground="#C00000"/>
                </Border>
                <ListView Grid.Row="1" x:Name="LeftOnlyList"
                          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="1">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DiffItemViewModel">
                            <StackPanel Padding="4,2">
                                <TextBlock Text="{x:Bind Key}" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{x:Bind Value}" FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- In Both -->
            <Grid Grid.Column="1" Margin="6,0,6,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" CornerRadius="4,4,0,0" Padding="8,6" Background="#E6F4EA">
                    <TextBlock Text="In Both" FontWeight="SemiBold" Foreground="#1A7F3C"/>
                </Border>
                <ListView Grid.Row="1" x:Name="MatchingList"
                          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="1">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DiffItemViewModel">
                            <StackPanel Padding="4,2">
                                <TextBlock Text="{x:Bind Key}" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{x:Bind Value}" FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Only in Right -->
            <Grid Grid.Column="2" Margin="6,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" CornerRadius="4,4,0,0" Padding="8,6" Background="#E6EEFF">
                    <TextBlock Text="Only in Right" FontWeight="SemiBold" Foreground="#0040B0"/>
                </Border>
                <ListView Grid.Row="1" x:Name="RightOnlyList"
                          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="1">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DiffItemViewModel">
                            <StackPanel Padding="4,2">
                                <TextBlock Text="{x:Bind Key}" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{x:Bind Value}" FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
