<Page
    x:Class="ConfigCompare.Desktop.Pages.ConfigurationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ConfigCompare.Desktop.ViewModels"
    xmlns:appconfig="using:ConfigCompare.AppConfig.Resources"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configurations"
                   Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="EndpointBox"
                     PlaceholderText="https://your-store.azconfig.io"
                     Margin="0,0,8,0"
                     KeyDown="EndpointBox_KeyDown"/>
            <Button Grid.Column="1" Content="Add Configuration"
                    Click="AddConfig_Click"
                    Style="{ThemeResource AccentButtonStyle}"/>
        </Grid>

        <ListView Grid.Row="2" x:Name="ConfigListView"
                  ItemsSource="{x:Bind ViewModel.Configurations}"
                  SelectionChanged="ConfigListView_SelectionChanged"
                  SelectionMode="Single"
                  Margin="0,0,0,8">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ConfigurationTabViewModel">
                    <Grid Padding="4,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind Endpoint}" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind StatusMessage, Mode=OneWay}" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                        <ProgressRing Grid.Column="1" IsActive="{x:Bind IsLoading, Mode=OneWay}"
                                      Width="20" Height="20" Margin="8,0"/>
                        <Button Grid.Column="2" Content="Remove"
                                Tag="{x:Bind}"
                                Click="RemoveConfig_Click"
                                Margin="4,0,0,0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Rectangle Grid.Row="3" Height="1"
                   Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                   Margin="0,4,0,8"/>

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Key-Value Pairs"
                       Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>
            <ListView Grid.Row="1" x:Name="KeyValueListView">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="appconfig:ConfigurationItemDto">
                        <Grid Padding="4,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Key}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind Value}"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind Label}"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
