<Page
    x:Class="ConfigCompare.Desktop.Pages.CopySettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16">
        <StackPanel MaxWidth="600" Spacing="12">
            <TextBlock Text="Copy Settings" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

            <TextBlock Text="Source Endpoint" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="SourceBox" PlaceholderText="https://source.azconfig.io"/>

            <TextBlock Text="Target Endpoint" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="TargetBox" PlaceholderText="https://target.azconfig.io"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Copy Settings" Click="Execute_Click"
                        Style="{ThemeResource AccentButtonStyle}"/>
                <Button Content="Clear" Click="Clear_Click"/>
                <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20"/>
            </StackPanel>

            <TextBlock x:Name="StatusText" Text="" TextWrapping="Wrap"/>

            <StackPanel x:Name="ResultsPanel" Visibility="Collapsed" Spacing="4">
                <TextBlock x:Name="CountText" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <TextBlock Text="Copied Keys:" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <ScrollViewer MaxHeight="200">
                    <TextBlock x:Name="CopiedKeysText" TextWrapping="Wrap" FontFamily="Consolas"/>
                </ScrollViewer>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
