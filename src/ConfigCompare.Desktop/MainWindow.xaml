<Window x:Class="ConfigCompare.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConfigCompare.Desktop"
        mc:Ignorable="d"
        Title="Configuration Comparison Tool" 
        Height="600" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <DockPanel>
        <!-- Header/Navigation Bar -->
        <StackPanel DockPanel.Dock="Top" 
                    Background="#2E2E2E" 
                    Height="50" 
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <TextBlock Text="ConfigCompare" 
                       Foreground="White" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center"
                       Margin="20,0,0,0" />
        </StackPanel>

        <!-- Tab Control -->
        <TabControl DockPanel.Dock="Top"
                    Background="White"
                    Margin="10">
            <!-- Comparison Tab -->
            <TabItem Header="Comparison" Padding="15,8">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20">
                        <TextBlock Text="Configuration Comparison" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,15" />
                        
                        <Grid ColumnDefinitions="*,*" Margin="0,0,0,15">
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Source Configuration" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,10" />
                                <TextBox Name="SourceConfigTextBox"
                                         MinHeight="200"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#F9F9F9"
                                         BorderBrush="#CCCCCC" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Target Configuration" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,10" />
                                <TextBox Name="TargetConfigTextBox"
                                         MinHeight="200"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#F9F9F9"
                                         BorderBrush="#CCCCCC" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Name="CompareButton"
                                    Content="Compare" 
                                    Padding="20,10" 
                                    Background="#007ACC" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Margin="0,0,10,0" />
                            <Button Name="ClearButton"
                                    Content="Clear" 
                                    Padding="20,10" 
                                    Background="#6C757D" 
                                    Foreground="White"
                                    FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Name="ComparisonResultsTextBlock"
                                   Margin="0,20,0,0"
                                   TextWrapping="Wrap"
                                   Background="#F0F0F0"
                                   Padding="15"
                                   MinHeight="100"
                                   Text="Comparison results will appear here..." 
                                   Foreground="#777777" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings" Padding="15,8">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20">
                        <TextBlock Text="Application Settings" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,15" />
                        
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Theme" FontWeight="Bold" Margin="0,0,0,10" />
                            <ComboBox Name="ThemeComboBox"
                                      SelectedIndex="0"
                                      MinWidth="200">
                                <ComboBoxItem>Light</ComboBoxItem>
                                <ComboBoxItem>Dark</ComboBoxItem>
                                <ComboBoxItem>System Default</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,20">
                            <CheckBox Content="Auto-refresh on changes" Margin="0,0,0,10" IsChecked="True" />
                            <CheckBox Content="Show detailed differences" Margin="0,0,0,10" IsChecked="True" />
                            <CheckBox Content="Enable notifications" IsChecked="False" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Button Name="SaveSettingsButton"
                                    Content="Save Settings" 
                                    Padding="20,10" 
                                    Background="#28A745" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Margin="0,0,10,0" />
                            <Button Name="ResetSettingsButton"
                                    Content="Reset to Default" 
                                    Padding="20,10" 
                                    Background="#6C757D" 
                                    Foreground="White"
                                    FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- About Tab -->
            <TabItem Header="About" Padding="15,8">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20" VerticalAlignment="Top">
                        <TextBlock Text="About Configuration Comparison Tool" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,20" />
                        
                        <TextBlock Text="Version: 1.0.0" Margin="0,0,0,10" />
                        <TextBlock Text="© 2026 All Rights Reserved" Margin="0,0,0,20" />
                        
                        <TextBlock Text="Features:" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10" />
                        <BulletDecorator Margin="20,0,0,5">
                            <BulletDecorator.Bullet>
                                <Ellipse Width="5" Height="5" Fill="Black" />
                            </BulletDecorator.Bullet>
                            <TextBlock Text="Side-by-side configuration comparison" />
                        </BulletDecorator>
                        <BulletDecorator Margin="20,0,0,5">
                            <BulletDecorator.Bullet>
                                <Ellipse Width="5" Height="5" Fill="Black" />
                            </BulletDecorator.Bullet>
                            <TextBlock Text="Customizable application settings" />
                        </BulletDecorator>
                        <BulletDecorator Margin="20,0,0,5">
                            <BulletDecorator.Bullet>
                                <Ellipse Width="5" Height="5" Fill="Black" />
                            </BulletDecorator.Bullet>
                            <TextBlock Text="Azure resource integration" />
                        </BulletDecorator>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
