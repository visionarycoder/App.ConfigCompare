<Window x:Class="ConfigCompare.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConfigCompare.Desktop"
        mc:Ignorable="d"
        Title="Configuration Comparison Tool" 
        Height="600" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <DockPanel>
        <!-- Header/Navigation Bar -->
        <StackPanel DockPanel.Dock="Left" 
                    Background="#2E2E2E" 
                    Width="60" 
                    Orientation="Vertical">
            <TextBlock Text="ConfigCompare" 
                       Foreground="White" 
                       FontSize="11" 
                       FontWeight="Bold" 
                       VerticalAlignment="Top"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="5,15,5,0" 
                       Height="40" />
            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,10">
                <Button Name="SettingsIconButton"
                        Content="⚙"
                        FontSize="24"
                        Width="45"
                        Height="45"
                        Background="#404040"
                        Foreground="White"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        Cursor="Hand" />
            </StackPanel>
        </StackPanel>

        <!-- Tab Control -->
        <TabControl DockPanel.Dock="Top"
                    Background="White"
                    Margin="10">
            <!-- Comparison Tab -->
            <TabItem Header="Comparison" Padding="15,8">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20">
                        <TextBlock Text="Configuration Comparison" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,15" />
                        
                        <Grid ColumnDefinitions="*,*" Margin="0,0,0,15">
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Source Configuration" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,10" />
                                <TextBox Name="SourceConfigTextBox"
                                         MinHeight="200"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#F9F9F9"
                                         BorderBrush="#CCCCCC" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Target Configuration" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,10" />
                                <TextBox Name="TargetConfigTextBox"
                                         MinHeight="200"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#F9F9F9"
                                         BorderBrush="#CCCCCC" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Name="CompareButton"
                                    Content="Compare" 
                                    Padding="20,10" 
                                    Background="#007ACC" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Margin="0,0,10,0" />
                            <Button Name="ClearButton"
                                    Content="Clear" 
                                    Padding="20,10" 
                                    Background="#6C757D" 
                                    Foreground="White"
                                    FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Name="ComparisonResultsTextBlock"
                                   Margin="0,20,0,0"
                                   TextWrapping="Wrap"
                                   Background="#F0F0F0"
                                   Padding="15"
                                   MinHeight="100"
                                   Text="Comparison results will appear here..." 
                                   Foreground="#777777" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings" Padding="15,8">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20">
                        <TextBlock Text="Application Settings" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,15" />
                        
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Theme" FontWeight="Bold" Margin="0,0,0,10" />
                            <ComboBox Name="ThemeComboBox"
                                      SelectedIndex="0"
                                      MinWidth="200">
                                <ComboBoxItem>Light</ComboBoxItem>
                                <ComboBoxItem>Dark</ComboBoxItem>
                                <ComboBoxItem>System Default</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,20">
                            <CheckBox Content="Auto-refresh on changes" Margin="0,0,0,10" IsChecked="True" />
                            <CheckBox Content="Show detailed differences" Margin="0,0,0,10" IsChecked="True" />
                            <CheckBox Content="Enable notifications" IsChecked="False" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Button Name="SaveSettingsButton"
                                    Content="Save Settings" 
                                    Padding="20,10" 
                                    Background="#28A745" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Margin="0,0,10,0" />
                            <Button Name="ResetSettingsButton"
                                    Content="Reset to Default" 
                                    Padding="20,10" 
                                    Background="#6C757D" 
                                    Foreground="White"
                                    FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- About Tab -->
            <TabItem Header="About" Padding="15,8">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20" VerticalAlignment="Top">
                        <TextBlock Text="About Configuration Comparison Tool" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,20" />
                        
                        <TextBlock Text="Version: 1.0.0" Margin="0,0,0,10" />
                        <TextBlock Text="© 2026 All Rights Reserved" Margin="0,0,0,20" />
                        
                        <TextBlock Text="Features:" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10" />
                        <BulletDecorator Margin="20,0,0,5">
                            <BulletDecorator.Bullet>
                                <Ellipse Width="5" Height="5" Fill="Black" />
                            </BulletDecorator.Bullet>
                            <TextBlock Text="Side-by-side configuration comparison" />
                        </BulletDecorator>
                        <BulletDecorator Margin="20,0,0,5">
                            <BulletDecorator.Bullet>
                                <Ellipse Width="5" Height="5" Fill="Black" />
                            </BulletDecorator.Bullet>
                            <TextBlock Text="Customizable application settings" />
                        </BulletDecorator>
                        <BulletDecorator Margin="20,0,0,5">
                            <BulletDecorator.Bullet>
                                <Ellipse Width="5" Height="5" Fill="Black" />
                            </BulletDecorator.Bullet>
                            <TextBlock Text="Azure resource integration" />
                        </BulletDecorator>
                        <BulletDecorator Margin="20,0,0,5">
                            <BulletDecorator.Bullet>
                                <Ellipse Width="5" Height="5" Fill="Black" />
                            </BulletDecorator.Bullet>
                            <TextBlock Text="Edit and commit configurations" />
                        </BulletDecorator>
                        <BulletDecorator Margin="20,0,0,5">
                            <BulletDecorator.Bullet>
                                <Ellipse Width="5" Height="5" Fill="Black" />
                            </BulletDecorator.Bullet>
                            <TextBlock Text="Find and replace values across configs" />
                        </BulletDecorator>
                        <BulletDecorator Margin="20,0,0,5">
                            <BulletDecorator.Bullet>
                                <Ellipse Width="5" Height="5" Fill="Black" />
                            </BulletDecorator.Bullet>
                            <TextBlock Text="Copy settings between instances" />
                        </BulletDecorator>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Edit Configuration Tab -->
            <TabItem Header="Edit Config" Padding="15,8">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20">
                        <TextBlock Text="Edit and Commit Configuration" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,15" />

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="App Configuration Endpoint" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBox Name="EditConfigEndpointTextBox"
                                     Padding="8"
                                     Background="#F9F9F9"
                                     BorderBrush="#CCCCCC" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Configuration Key *" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBox Name="ConfigKeyTextBox"
                                     Padding="8"
                                     Background="#F9F9F9"
                                     BorderBrush="#CCCCCC" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Configuration Value *" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBox Name="ConfigValueTextBox"
                                     MinHeight="100"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="8"
                                     Background="#F9F9F9"
                                     BorderBrush="#CCCCCC" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Configuration Label (optional)" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBox Name="ConfigLabelTextBox"
                                     Padding="8"
                                     Background="#F9F9F9"
                                     BorderBrush="#CCCCCC" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Name="SaveConfigButton"
                                    Content="Save Configuration" 
                                    Padding="20,10" 
                                    Background="#007ACC" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Margin="0,0,10,0" />
                            <Button Name="ClearEditConfigButton"
                                    Content="Clear Form" 
                                    Padding="20,10" 
                                    Background="#6C757D" 
                                    Foreground="White"
                                    FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Name="EditConfigStatusTextBlock"
                                   Margin="0,0,0,0"
                                   TextWrapping="Wrap"
                                   Background="#F0F0F0"
                                   Padding="15"
                                   MinHeight="80"
                                   Text="Status messages will appear here..." 
                                   Foreground="#777777" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Find and Replace Tab -->
            <TabItem Header="Find &amp; Replace" Padding="15,8">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20">
                        <TextBlock Text="Find and Replace Values" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,15" />

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="App Configuration Endpoint" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBox Name="FindReplaceEndpointTextBox"
                                     Padding="8"
                                     Background="#F9F9F9"
                                     BorderBrush="#CCCCCC" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" Margin="0,0,0,15">
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Find Value" FontWeight="Bold" Margin="0,0,0,5" />
                                <TextBox Name="FindValueTextBox"
                                         MinHeight="60"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="8"
                                         Background="#F9F9F9"
                                         BorderBrush="#CCCCCC" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Replace With" FontWeight="Bold" Margin="0,0,0,5" />
                                <TextBox Name="ReplaceValueTextBox"
                                         MinHeight="60"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="8"
                                         Background="#F9F9F9"
                                         BorderBrush="#CCCCCC" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Name="ExecuteFindReplaceButton"
                                    Content="Find &amp; Replace" 
                                    Padding="20,10" 
                                    Background="#FFC107" 
                                    Foreground="Black"
                                    FontWeight="Bold"
                                    Margin="0,0,10,0" />
                            <Button Name="ClearFindReplaceButton"
                                    Content="Clear Form" 
                                    Padding="20,10" 
                                    Background="#6C757D" 
                                    Foreground="White"
                                    FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Name="FindReplaceStatusTextBlock"
                                   Margin="0,0,0,10"
                                   TextWrapping="Wrap"
                                   Background="#F0F0F0"
                                   Padding="15"
                                   MinHeight="60"
                                   Text="Status messages will appear here..." 
                                   Foreground="#777777" />

                        <TextBlock Text="Affected Keys:" FontWeight="Bold" Margin="0,0,0,5" />
                        <TextBox Name="AffectedKeysTextBox"
                                 MinHeight="80"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#F9F9F9"
                                 Padding="8"
                                 BorderBrush="#CCCCCC" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Copy Settings Tab -->
            <TabItem Header="Copy Settings" Padding="15,8">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20">
                        <TextBlock Text="Copy Settings Between Instances" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,15" />

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Source Endpoint" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBox Name="CopySourceEndpointTextBox"
                                     Padding="8"
                                     Background="#F9F9F9"
                                     BorderBrush="#CCCCCC" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Target Endpoint" FontWeight="Bold" Margin="0,0,0,5" />
                            <TextBox Name="CopyTargetEndpointTextBox"
                                     Padding="8"
                                     Background="#F9F9F9"
                                     BorderBrush="#CCCCCC" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Name="ExecuteCopySettingsButton"
                                    Content="Copy Settings" 
                                    Padding="20,10" 
                                    Background="#28A745" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Margin="0,0,10,0" />
                            <Button Name="ClearCopySettingsButton"
                                    Content="Clear Form" 
                                    Padding="20,10" 
                                    Background="#6C757D" 
                                    Foreground="White"
                                    FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Name="CopySettingsStatusTextBlock"
                                   Margin="0,0,0,10"
                                   TextWrapping="Wrap"
                                   Background="#F0F0F0"
                                   Padding="15"
                                   MinHeight="60"
                                   Text="Status messages will appear here..." 
                                   Foreground="#777777" />

                        <TextBlock Text="Copied Keys:" FontWeight="Bold" Margin="0,0,0,5" />
                        <TextBox Name="CopiedKeysTextBox"
                                 MinHeight="100"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#F9F9F9"
                                 Padding="8"
                                 BorderBrush="#CCCCCC" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Settings Popup Overlay -->
        <Grid Name="SettingsPopupOverlay" 
              Background="#80000000" 
              Visibility="Hidden"
              ZIndex="1000"
              MouseDown="SettingsPopupOverlay_MouseDown">
            <Border Background="White" 
                    BorderBrush="#CCCCCC" 
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="50"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="500">
                <StackPanel Orientation="Vertical" Margin="30">
                    <!-- Close Button -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
                        <Button Name="CloseSettingsButton"
                                Content="✕"
                                FontSize="16"
                                Width="30"
                                Height="30"
                                Background="#F0F0F0"
                                Foreground="Black"
                                BorderThickness="0"
                                Cursor="Hand" />
                    </StackPanel>

                    <!-- Settings/About Content -->
                    <TabControl Name="SettingsTabControl" Margin="0,0,0,20">
                        <!-- Settings Tab -->
                        <TabItem Header="Settings" Padding="15,8">
                            <StackPanel Orientation="Vertical" Margin="15" Background="White">
                                <TextBlock Text="Application Preferences" 
                                           FontSize="14" 
                                           FontWeight="Bold"
                                           Margin="0,0,0,15" />
                                
                                <StackPanel Margin="0,0,0,15">
                                    <TextBlock Text="Theme" FontWeight="Bold" Margin="0,0,0,8" />
                                    <ComboBox Name="SettingsThemeComboBox"
                                              SelectedIndex="0"
                                              MinWidth="200">
                                        <ComboBoxItem>Light</ComboBoxItem>
                                        <ComboBoxItem>Dark</ComboBoxItem>
                                        <ComboBoxItem>System Default</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,15">
                                    <CheckBox Content="Auto-refresh on changes" Margin="0,0,0,8" IsChecked="True" />
                                    <CheckBox Content="Show detailed differences" Margin="0,0,0,8" IsChecked="True" />
                                    <CheckBox Content="Enable notifications" IsChecked="False" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button Name="SaveSettingsPopupButton"
                                            Content="Save" 
                                            Padding="15,8" 
                                            Background="#28A745" 
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Margin="0,0,10,0" />
                                    <Button Name="ResetSettingsPopupButton"
                                            Content="Reset" 
                                            Padding="15,8" 
                                            Background="#6C757D" 
                                            Foreground="White"
                                            FontWeight="Bold" />
                                </StackPanel>
                            </StackPanel>
                        </TabItem>

                        <!-- About Tab -->
                        <TabItem Header="About" Padding="15,8">
                            <StackPanel Orientation="Vertical" Margin="15" Background="White" VerticalAlignment="Top">
                                <TextBlock Name="AppVersionTextBlock"
                                           Text="Configuration Comparison Tool"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5" />
                                
                                <TextBlock Name="VersionNumberTextBlock"
                                           Text="Version: 1.0.0"
                                           Margin="0,0,0,15"
                                           Foreground="#666666" />
                                
                                <TextBlock Text="© 2026 All Rights Reserved" 
                                           Margin="0,0,0,20"
                                           FontSize="11"
                                           Foreground="#777777" />
                                
                                <TextBlock Text="About This Application" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,10" />
                                
                                <TextBlock Text="A powerful tool for comparing and managing Azure configuration settings across multiple environments. Features side-by-side comparison, find and replace, cross-instance synchronization, and Azure integration."
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,15"
                                           FontSize="11" />
                                
                                <TextBlock Text="Key Features:" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,10" />
                                
                                <TextBlock Text="• Side-by-side configuration comparison" TextWrapping="Wrap" Margin="0,0,0,5" FontSize="11" />
                                <TextBlock Text="• Azure App Configuration integration" TextWrapping="Wrap" Margin="0,0,0,5" FontSize="11" />
                                <TextBlock Text="• Find and replace values across configs" TextWrapping="Wrap" Margin="0,0,0,5" FontSize="11" />
                                <TextBlock Text="• Copy settings between instances" TextWrapping="Wrap" Margin="0,0,0,5" FontSize="11" />
                                <TextBlock Text="• Customizable application settings" TextWrapping="Wrap" Margin="0,0,0,15" FontSize="11" />

                                <TextBlock Text="Support &amp; Documentation" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,10" />
                                
                                <TextBlock Text="For more information, documentation, and support, visit the project repository or contact support."
                                           TextWrapping="Wrap"
                                           FontSize="11"
                                           Foreground="#666666" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
